# cmake/RunDedupHeaders.cmake Invoked as a cmake -P script at build time (POST_BUILD on the _native target). Runs
# dedup_headers on all .h files generated by the Rust build so that downstream C/C++ code can include them without
# multiple-definition errors.
#
# Required variables (passed via -D on the cmake -P command line): HEADERS_DIR        — directory containing the
# generated *.h files DEDUP_HEADERS_EXE  — path to the dedup_headers binary NATIVE_LIB         — path to
# lib_native.dylib/.so (used for fingerprinting)
#
# AIDEV-NOTE: Fingerprint-based skip: we hash NATIVE_LIB and store the result in HEADERS_DIR/.dedup_fingerprint.  If the
# hash is unchanged we skip running dedup_headers, which preserves the header file mtimes and prevents Ninja from
# re-running downstream C/C++ compilation targets unnecessarily.

if(NOT EXISTS "${HEADERS_DIR}")
    message(STATUS "dedup_headers: ${HEADERS_DIR} does not exist yet, skipping")
    return()
endif()

file(
    GLOB _header_files
    RELATIVE "${HEADERS_DIR}"
    "${HEADERS_DIR}/*.h")

if(NOT _header_files)
    message(STATUS "dedup_headers: no *.h files found in ${HEADERS_DIR}, skipping")
    return()
endif()

# ── Fingerprint check ─────────────────────────────────────────────────────────
set(_fingerprint_file "${HEADERS_DIR}/.dedup_fingerprint")
set(_current_hash "")
if(NATIVE_LIB AND EXISTS "${NATIVE_LIB}")
    file(MD5 "${NATIVE_LIB}" _current_hash)
    if(EXISTS "${_fingerprint_file}")
        file(READ "${_fingerprint_file}" _stored_hash)
        string(STRIP "${_stored_hash}" _stored_hash)
        if("${_current_hash}" STREQUAL "${_stored_hash}")
            message(STATUS "dedup_headers: lib_native unchanged (${_current_hash}), skipping")
            return()
        endif()
    endif()
endif()

execute_process(
    COMMAND "${DEDUP_HEADERS_EXE}" ${_header_files}
    WORKING_DIRECTORY "${HEADERS_DIR}"
    RESULT_VARIABLE _result)

if(_result AND NOT _result EQUAL 0)
    message(WARNING "dedup_headers returned non-zero exit status ${_result}")
endif()

# Update fingerprint so the next build skips if lib_native is unchanged.
if(_current_hash)
    file(WRITE "${_fingerprint_file}" "${_current_hash}")
endif()
