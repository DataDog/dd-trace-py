#!/usr/bin/env scripts/uv-run-script
# -*- mode: python -*-
# /// script
# dependencies = []
# ///
"""
Compile locked benchmark requirements from per-scenario .in files.

Each benchmark scenario with extra dependencies has:
  benchmarks/<scenario>/requirements_scenario.in   (manually maintained, top-level deps)
  benchmarks/base/requirements.in                  (shared base deps for all scenarios)

This script:
  1. Compiles benchmarks/base/requirements.in into a hash-locked base/requirements.txt.
     The -r requirements_scenario.txt line is prepended so that scenarios with extra
     deps can override it via their own requirements_scenario.txt.
  2. For each scenario with a requirements_scenario.in, compiles base + scenario sources
     together into a single hash-locked requirements_scenario.txt covering all
     transitive dependencies.

Scenarios without a requirements_scenario.in are base-only: they use base/requirements.txt
directly and no separate lock file is needed.

Usage:
    scripts/update-benchmark-dependencies

To add a new scenario dependency:
1. Create (or edit) benchmarks/<scenario>/requirements_scenario.in with top-level deps
2. Run this script to regenerate the locked requirements_scenario.txt
3. Commit both files

To add a new base dependency (available to all scenarios):
1. Add it to benchmarks/base/requirements.in
2. Run this script to regenerate base/requirements.txt AND all scenario lock files
3. Commit all changed files
"""

import subprocess
import sys
from pathlib import Path


BASE_IN = Path("benchmarks/base/requirements.in")
BASE_TXT = Path("benchmarks/base/requirements.txt")

# Python version must match benchmarks/Dockerfile PYTHON_VERSION
PYTHON_VERSION = "3.9"
PYTHON_PLATFORM = "linux"


def find_scenario_dirs() -> list[Path]:
    """Return sorted list of scenario directories with a non-empty requirements_scenario.in."""
    benchmarks_dir = Path("benchmarks")
    result = []
    for p in sorted(benchmarks_dir.glob("*/requirements_scenario.in")):
        if p.parent.name in ("base", "bm"):
            continue
        result.append(p.parent)
    return result


def run_compile(inputs: list[Path], output: Path) -> bool:
    """
    Run uv pip compile to generate a hash-locked requirements file.

    Returns True on success, False on failure.
    """
    try:
        result = subprocess.run(
            [
                "uv",
                "pip",
                "compile",
                "--upgrade",
                "--python-platform",
                PYTHON_PLATFORM,
                "--python-version",
                PYTHON_VERSION,
                "--output-file",
                str(output),
                *[str(i) for i in inputs],
            ],
            capture_output=True,
            text=True,
            check=True,
        )
        if result.stderr:
            pass  # uv writes progress to stderr; only surface on failure
        return True

    except FileNotFoundError:
        print("  Error: uv not found. Install it from https://github.com/astral-sh/uv", file=sys.stderr)
        return False

    except subprocess.CalledProcessError as e:
        print(f"  Error compiling {output}:", file=sys.stderr)
        if e.stdout:
            print(e.stdout, file=sys.stderr)
        if e.stderr:
            print(e.stderr, file=sys.stderr)
        return False


def compile_base() -> bool:
    """
    Compile base/requirements.in -> base/requirements.txt.

    Prepends '-r requirements_scenario.txt' so that scenario images can override
    the scenario-specific portion of the install via their own lock file.
    """
    print("  Compiling base...")
    if not run_compile([BASE_IN], BASE_TXT):
        return False

    # Prepend the -r directive that pulls in per-scenario overrides.
    # uv compile output is the locked packages only; we add the header by hand.
    existing = BASE_TXT.read_text()
    header = (
        "# This file is auto-maintained by scripts/update-benchmark-dependencies.\n"
        "# Scenarios with extra dependencies override the install via their own\n"
        "# requirements_scenario.txt (which is a combined base+scenario lock).\n"
        "# Do not edit this file directly — edit benchmarks/base/requirements.in\n"
        "# and re-run scripts/update-benchmark-dependencies.\n"
        "#\n"
        "# NOTE: Hashes are intentionally omitted. The benchmarking-platform installs\n"
        "# the ddtrace wheel alongside this file in a single pip invocation; if hashes\n"
        "# were present, pip would require the wheel to have a hash too (--require-hashes\n"
        "# mode), which fails for locally-built wheels.\n"
        "-r requirements_scenario.txt\n"
        "\n"
    )
    BASE_TXT.write_text(header + existing)
    print(f"    → {BASE_TXT}")
    return True


def compile_scenario(scenario_dir: Path) -> bool:
    """
    Compile base + scenario requirements into a combined locked requirements_scenario.txt.

    The combined lock covers all transitive dependencies so the two locks (base and
    scenario) don't conflict at install time under --require-hashes mode.

    Returns True on success, False on failure.
    """
    scenario_in = scenario_dir / "requirements_scenario.in"
    scenario_txt = scenario_dir / "requirements_scenario.txt"

    print(f"  Compiling {scenario_dir.name}...")
    if not run_compile([BASE_IN, scenario_in], scenario_txt):
        return False
    print(f"    → {scenario_txt}")
    return True


def main() -> int:
    """Main entry point."""
    if not BASE_IN.exists():
        print(f"Error: {BASE_IN} not found", file=sys.stderr)
        return 1

    failed: list[str] = []

    # 1. Lock the base requirements
    if not compile_base():
        failed.append("base")

    # 2. Lock each scenario that has extra deps
    scenario_dirs = find_scenario_dirs()
    print(f"\nFound {len(scenario_dirs)} scenario(s) with extra dependencies:")
    for scenario_dir in scenario_dirs:
        if not compile_scenario(scenario_dir):
            failed.append(scenario_dir.name)

    if failed:
        print(f"\n❌ Failed to compile: {', '.join(failed)}")
        return 1

    print(f"\n✅ Compiled base + {len(scenario_dirs)} scenario lock file(s)")
    print("\nNext steps:")
    print("  1. Review the generated lock files")
    print("  2. Run scripts/check-benchmark-dependencies to verify the check passes")
    print("  3. Commit all changes (benchmarks/base/requirements.txt + any requirements_scenario.txt)")
    return 0


if __name__ == "__main__":
    sys.exit(main())
