#!/usr/bin/env scripts/uv-run-script
# -*- mode: python -*-
# /// script
# requires-python = ">=3.8"
# dependencies = []
# ///
"""Analyze benchmark artifacts from perf-run-scenario runs.

Reads pyperf result JSON files from an artifacts directory and produces
summary tables, comparisons, and optional viztracer profiling analysis.

Usage:
  # Summarize results from a run (auto-finds latest run ID)
  scripts/perf-analyze artifacts/

  # Summarize a specific run ID
  scripts/perf-analyze artifacts/<run-id>/

  # Show top functions from viztracer profiling data
  scripts/perf-analyze artifacts/ --profile-top 20

  # Filter profiling output to ddtrace functions only
  scripts/perf-analyze artifacts/ --profile-top 20 --filter ddtrace

  # Compare profiling between baseline and candidate (ddtrace hot paths only)
  scripts/perf-analyze artifacts/ --profile-compare --filter ddtrace --min-calls 1000

  # Save pstats .prof files for interactive analysis with python -m pstats
  scripts/perf-analyze artifacts/ --save-pstats

  # Output JSON for AI agent consumption
  scripts/perf-analyze artifacts/ --json

  # Output Markdown table for PR comments
  scripts/perf-analyze artifacts/ --markdown
"""

import argparse
import json
import os
from pathlib import Path
import pstats
import re
import statistics
import sys


_SITE_PACKAGES_RE = re.compile(r"/app/\.venv/lib/python\d+\.\d+/site-packages/")
_VENV_RE_PATTERN = r"/app/\.venv_ddtrace_v[12]/"
_NAME_RE = re.compile(r"^(.*?) \((.+):(\d+)\)$")


class _VizProfile:
    """Duck-typed profiler accepted by pstats.Stats constructor.

    pstats.Stats.__init__ dispatches on hasattr(arg, 'create_stats'), so any
    object with create_stats() and a .stats attribute works — no temp files or
    marshal needed.
    """

    def __init__(self, stats: dict):
        self.stats = stats

    def create_stats(self):
        pass


def find_run_dir(artifacts_path: Path) -> Path:
    """Find the run directory inside an artifacts path.

    If the path already contains scenario subdirs (with baseline/candidate), use it directly.
    Otherwise, find UUID-named subdirs and use the most recently modified one.
    """
    for child in artifacts_path.iterdir():
        if child.is_dir():
            if (child / "baseline").exists() or (child / "candidate").exists():
                return artifacts_path

    run_dirs = sorted(
        [d for d in artifacts_path.iterdir() if d.is_dir()],
        key=lambda d: d.stat().st_mtime,
        reverse=True,
    )
    if not run_dirs:
        print(f"Error: No run directories found in {artifacts_path}", file=sys.stderr)
        sys.exit(1)

    return run_dirs[0]


def load_pyperf_result(path: Path) -> dict:
    """Load a pyperf result JSON file and extract key stats."""
    try:
        with open(path) as f:
            data = json.load(f)

        metadata = data.get("metadata", {})
        loops = metadata.get("loops", 1)
        name = metadata.get("name", path.stem)
        unit = metadata.get("unit", "second")

        benchmarks = data.get("benchmarks", [])
        if not benchmarks:
            raise ValueError("No benchmarks in result file")

        # Collect measurement values; runs lacking a "values" key are calibration/warmup runs
        # pyperf stores values already normalized per-iteration (divided by loops internally),
        # so we must NOT divide by loops again here.
        values = []
        for run in benchmarks[0]["runs"]:
            if "values" in run:
                values.extend(run["values"])

        return {
            "name": name,
            "path": str(path),
            "loops": loops,
            "unit": unit,
            "values": values,
            "mean": statistics.mean(values) if values else 0,
            "stdev": statistics.stdev(values) if len(values) > 1 else 0,
            "median": statistics.median(values) if values else 0,
            "min": min(values) if values else 0,
            "max": max(values) if values else 0,
            "n_samples": len(values),
        }
    except Exception as e:
        print(f"Warning: Failed to load {path}: {e}", file=sys.stderr)
        return None


def discover_results(run_dir: Path) -> dict:
    """Discover all benchmark results in a run directory.

    Returns: {scenario: {config: {"baseline": stats, "candidate": stats}}}
    """
    results = {}

    for scenario_dir in sorted(run_dir.iterdir()):
        if not scenario_dir.is_dir():
            continue

        scenario = scenario_dir.name
        results[scenario] = {}

        for version in ["baseline", "candidate"]:
            version_dir = scenario_dir / version
            if not version_dir.exists():
                continue

            for result_file in sorted(version_dir.glob("results.*.json")):
                config = result_file.stem[len("results."):]
                if config not in results[scenario]:
                    results[scenario][config] = {}
                stats = load_pyperf_result(result_file)
                if stats is not None:
                    results[scenario][config][version] = stats

            single = version_dir / "results.json"
            if single.exists():
                config = "default"
                if config not in results[scenario]:
                    results[scenario][config] = {}
                stats = load_pyperf_result(single)
                if stats is not None:
                    results[scenario][config][version] = stats

    return results


def format_time(seconds: float) -> str:
    """Format a time value with appropriate unit."""
    abs_s = abs(seconds)
    if abs_s >= 1.0:
        return f"{seconds:.3f} s"
    elif abs_s >= 1e-3:
        return f"{seconds * 1e3:.2f} ms"
    elif abs_s >= 1e-6:
        return f"{seconds * 1e6:.2f} us"
    else:
        return f"{seconds * 1e9:.2f} ns"


def print_summary(results: dict) -> None:
    """Print a human-readable summary table of benchmark results."""
    for scenario, configs in results.items():
        print(f"\n{'=' * 70}")
        print(f"Scenario: {scenario}")
        print(f"{'=' * 70}")

        for config, versions in sorted(configs.items()):
            baseline = versions.get("baseline")
            candidate = versions.get("candidate")

            if baseline and candidate:
                change = (candidate["mean"] - baseline["mean"]) / baseline["mean"] * 100
                ratio = candidate["mean"] / baseline["mean"] if baseline["mean"] else 0

                if abs(change) < 2:
                    sig = "not significant"
                elif change < 0:
                    sig = f"{abs(change):.1f}% faster"
                else:
                    sig = f"{change:.1f}% slower"

                ratio_str = f"{1/ratio:.2f}x faster" if ratio < 1 else (f"{ratio:.2f}x slower" if ratio > 1 else "same")

                print(f"\n  {config}:")
                print(f"    baseline:  {format_time(baseline['mean'])} +/- {format_time(baseline['stdev'])}")
                print(f"    candidate: {format_time(candidate['mean'])} +/- {format_time(candidate['stdev'])}")
                print(f"    change:    {change:+.2f}% ({ratio_str}) [{sig}]")
                print(f"    baseline  samples={baseline['n_samples']}, "
                      f"min={format_time(baseline['min'])}, "
                      f"median={format_time(baseline['median'])}, "
                      f"max={format_time(baseline['max'])}")
                print(f"    candidate samples={candidate['n_samples']}, "
                      f"min={format_time(candidate['min'])}, "
                      f"median={format_time(candidate['median'])}, "
                      f"max={format_time(candidate['max'])}")

            elif baseline:
                print(f"\n  {config}:")
                print(f"    baseline:  {format_time(baseline['mean'])} +/- {format_time(baseline['stdev'])}")
                print(f"    candidate: (not available)")
            elif candidate:
                print(f"\n  {config}:")
                print(f"    baseline:  (not available)")
                print(f"    candidate: {format_time(candidate['mean'])} +/- {format_time(candidate['stdev'])}")


def _stddev_overlaps(b_mean: float, b_std: float, c_mean: float, c_std: float) -> bool:
    """True if the 1-sigma bands of baseline and candidate overlap.

    When True, the measured difference may not be reproducible even if the
    change_percent exceeds the 2% significance threshold.
    """
    return (b_mean - b_std) <= (c_mean + c_std) and (c_mean - c_std) <= (b_mean + b_std)


def output_json(results: dict) -> None:
    """Output results as JSON for AI agent consumption."""
    output = {}
    for scenario, configs in results.items():
        output[scenario] = {}
        for config, versions in configs.items():
            entry = {}
            for version_name, stats in versions.items():
                entry[version_name] = {
                    "mean_seconds": stats["mean"],
                    "stdev_seconds": stats["stdev"],
                    "median_seconds": stats["median"],
                    "min_seconds": stats["min"],
                    "max_seconds": stats["max"],
                    "n_samples": stats["n_samples"],
                    "mean_human": format_time(stats["mean"]),
                    "stdev_human": format_time(stats["stdev"]),
                }
            if "baseline" in entry and "candidate" in entry:
                b = entry["baseline"]["mean_seconds"]
                c = entry["candidate"]["mean_seconds"]
                change_pct = (c - b) / b * 100 if b else 0
                ratio = c / b if b else 0
                entry["comparison"] = {
                    "change_percent": round(change_pct, 2),
                    "ratio": round(ratio, 4),
                    "significant": abs(change_pct) >= 2,
                    "regression": change_pct > 2,
                    "overlapping_stddev": _stddev_overlaps(
                        entry["baseline"]["mean_seconds"], entry["baseline"]["stdev_seconds"],
                        entry["candidate"]["mean_seconds"], entry["candidate"]["stdev_seconds"],
                    ),
                }
            output[scenario][config] = entry
    print(json.dumps(output, indent=2))


def output_markdown(results: dict) -> None:
    """Output results as a Markdown table for copy-paste into PR comments."""
    print("| Benchmark | Baseline | Candidate | Change |")
    print("|-----------|----------|-----------|--------|")
    for scenario, configs in results.items():
        for config, versions in sorted(configs.items()):
            baseline = versions.get("baseline")
            candidate = versions.get("candidate")
            if baseline and candidate:
                change = (candidate["mean"] - baseline["mean"]) / baseline["mean"] * 100
                print(
                    f"| {scenario}/{config}"
                    f" | {format_time(baseline['mean'])} ± {format_time(baseline['stdev'])}"
                    f" | {format_time(candidate['mean'])} ± {format_time(candidate['stdev'])}"
                    f" | {change:+.2f}% |"
                )
            elif baseline:
                print(f"| {scenario}/{config} | {format_time(baseline['mean'])} | — | — |")
            elif candidate:
                print(f"| {scenario}/{config} | — | {format_time(candidate['mean'])} | — |")


def discover_viztracer_files(run_dir: Path) -> dict:
    """Discover viztracer profiling files.

    Returns: {scenario: {config: {"baseline": path, "candidate": path}}}
    """
    profiles = {}
    for scenario_dir in sorted(run_dir.iterdir()):
        if not scenario_dir.is_dir():
            continue
        scenario = scenario_dir.name
        profiles[scenario] = {}
        for version in ["baseline", "candidate"]:
            vt_dir = scenario_dir / version / "viztracer"
            if not vt_dir.exists():
                continue
            for vt_file in sorted(vt_dir.glob("*.json")):
                config = vt_file.stem
                if config not in profiles[scenario]:
                    profiles[scenario][config] = {}
                profiles[scenario][config][version] = vt_file
    return profiles


def _normalize_name(name: str) -> str:
    """Normalize viztracer function names: collapse venv paths."""
    return re.sub(_VENV_RE_PATTERN, "/app/.venv/", name)


def _comparison_key(name: str) -> str:
    """Strip line numbers for cross-version comparison.

    Viztracer records 'func_name (path/to/file.py:123)'. When a refactor shifts
    line numbers, the same function gets two different entries. Stripping the
    line number lets us match functions by name+file across versions.
    """
    return re.sub(r":(\d+)\)", ")", name)


def _display_name(filename: str) -> str:
    """Shorten a filename by stripping the site-packages prefix."""
    return _SITE_PACKAGES_RE.sub("", filename)


def _parse_viz_name(name: str) -> tuple:
    """Parse viztracer 'func_name (path/to/file.py:123)' -> (filename, lineno, func_name).

    Applies _display_name to the filename so pstats output shows short paths.
    """
    m = _NAME_RE.match(name)
    if m:
        func_name, filename, lineno = m.group(1), m.group(2), int(m.group(3))
        return _display_name(filename), lineno, func_name
    return "<unknown>", 0, name


def viztracer_to_pstats(
    vt_path: Path,
    filter_str: str = "",
    strip_lineno: bool = False,
    min_calls: int = 0,
) -> pstats.Stats:
    """Convert a viztracer Chrome Trace JSON to an in-memory pstats.Stats object.

    Reconstructs the call tree from event timestamps to compute exclusive
    tottime (time spent in the function itself, excluding subcalls). viztracer
    'dur' fields are in microseconds; pstats expects seconds.

    The call tree is reconstructed per-thread using a stack: each event's
    duration is subtracted from its direct parent's tottime accumulator, so
    tottime[f] = cumtime[f] - sum(direct_children[f].cumtime).
    """
    with open(vt_path) as f:
        data = json.load(f)

    # Collect X (complete duration) events by thread, applying pre-filter
    events_by_tid = {}
    for event in data.get("traceEvents", []):
        if event.get("ph") != "X":
            continue
        name = _normalize_name(event.get("name", ""))
        if filter_str and filter_str not in name:
            continue
        tid = event.get("tid", 0)
        ts = event.get("ts", 0)
        dur = event.get("dur", 0)
        events_by_tid.setdefault(tid, []).append((ts, dur, name))

    # Aggregate per pstats key: [ncalls, tottime_us, cumtime_us]
    # tottime starts equal to cumtime; direct children subtract from it.
    agg = {}

    # callers_agg[callee_key][caller_key] = [ncalls, cumtime_us]
    # Populated during the same stack walk used for tottime.
    callers_agg = {}

    for events in events_by_tid.values():
        events.sort(key=lambda e: e[0])  # sort by timestamp

        # Stack of (end_ts, pstats_key) for tracking parent-child relationships
        stack = []

        for ts, dur, name in events:
            filename, lineno, func_name = _parse_viz_name(name)
            if strip_lineno:
                lineno = 0  # zero lineno so same function at different lines merges as one key
            key = (filename, lineno, func_name)

            # Pop stack entries that ended before this event starts
            while stack and stack[-1][0] <= ts:
                stack.pop()

            # Direct parent: subtract this event's inclusive dur from parent's tottime.
            # This progressively turns cumtime into exclusive tottime for each ancestor.
            # Clamp at zero: overlapping events from instrumentation overhead can
            # cause children's cumtime to exceed the parent's, and letting tottime
            # go negative here would cascade incorrect subtractions to later siblings.
            if stack:
                parent_key = stack[-1][1]
                agg[parent_key][1] = max(0, agg[parent_key][1] - dur)

                # Record caller relationship: this key was called by parent_key
                callee_callers = callers_agg.setdefault(key, {})
                if parent_key in callee_callers:
                    callee_callers[parent_key][0] += 1
                    callee_callers[parent_key][1] += dur
                else:
                    callee_callers[parent_key] = [1, dur]  # [ncalls, cumtime_us]

            # Accumulate this event
            if key in agg:
                agg[key][0] += 1
                agg[key][1] += dur
                agg[key][2] += dur
            else:
                agg[key] = [1, dur, dur]  # [ncalls, tottime_us, cumtime_us]

            stack.append((ts + dur, key))

    # Apply min-calls filter before building pstats object
    if min_calls:
        agg = {k: v for k, v in agg.items() if v[0] >= min_calls}

    # pstats callers dict format: {caller_key: (cc, nc, tt, ct)}
    # We use cumtime for both tt and ct since per-caller tottime requires
    # tracking child subtractions per (caller, callee) pair — not worth the
    # complexity; cumtime is accurate and call counts are exact.
    def _build_callers(key):
        callers = callers_agg.get(key, {})
        return {
            ck: (v[0], v[0], v[1] / 1e6, v[1] / 1e6)
            for ck, v in callers.items()
            if ck in agg  # drop callers filtered out by min_calls
        }

    # pstats dict format: {(filename, lineno, func_name): (cc, nc, tt, ct, callers)}
    # cc = primitive calls, nc = total calls, tt = tottime (s), ct = cumtime (s)
    stats_dict = {
        key: (v[0], v[0], v[1] / 1e6, v[2] / 1e6, _build_callers(key))
        for key, v in agg.items()
    }

    return pstats.Stats(_VizProfile(stats_dict), stream=sys.stdout)


def print_call_tree(
    profiles: dict,
    func_pattern: str,
    filter_str: str = "",
    min_calls: int = 0,
) -> None:
    """Show callers and callees for functions matching func_pattern."""
    for scenario, configs in profiles.items():
        for config, versions in sorted(configs.items()):
            for version, path in sorted(versions.items()):
                size_mb = path.stat().st_size / (1024 * 1024)
                print(f"\n{'=' * 78}")
                print(f"Profile: {scenario}/{config} ({version}) [{size_mb:.0f} MB]")
                print(f"{'=' * 78}")
                print(f"  Loading {path}...", file=sys.stderr)

                stats = viztracer_to_pstats(path, filter_str=filter_str, min_calls=min_calls)
                stats.sort_stats("tottime")
                print("\nCallers:")
                stats.print_callers(func_pattern)
                print("\nCallees:")
                stats.print_callees(func_pattern)


def _sort_stats(stats: pstats.Stats, sort_key: str) -> None:
    """Sort a pstats.Stats object, supporting 'percall' (tottime/ncalls) in addition to
    the native pstats sort keys."""
    if sort_key == "percall":
        # pstats has no native per-call sort — build fcn_list and sort by tottime/ncalls
        stats.sort_stats("tottime")  # populates fcn_list
        stats.fcn_list.sort(
            key=lambda k: stats.stats[k][2] / stats.stats[k][1] if stats.stats[k][1] else 0,
            reverse=True,
        )
    else:
        stats.sort_stats(sort_key)


def print_profile_top(
    profiles: dict,
    top_n: int,
    filter_str: str = "",
    sort_key: str = "tottime",
    min_calls: int = 0,
    save_pstats: bool = False,
) -> None:
    """Print top functions from viztracer profiling data."""
    col_w = 80
    for scenario, configs in profiles.items():
        for config, versions in sorted(configs.items()):
            for version, path in sorted(versions.items()):
                size_mb = path.stat().st_size / (1024 * 1024)
                notes = []
                if filter_str:
                    notes.append(f"filter={filter_str!r}")
                if min_calls:
                    notes.append(f"min_calls={min_calls}")
                notes_str = f" [{', '.join(notes)}]" if notes else ""
                print(f"\n{'=' * (col_w + 52)}")
                print(f"Profile: {scenario}/{config} ({version}) [{size_mb:.0f} MB]{notes_str}")
                print(f"{'=' * (col_w + 52)}")
                print(f"  Loading {path}...", file=sys.stderr)

                stats = viztracer_to_pstats(path, filter_str=filter_str, min_calls=min_calls)
                _sort_stats(stats, sort_key)
                funcs = (stats.fcn_list or list(stats.stats.keys()))[:top_n]

                print(f"\n  {'Function':<{col_w}} {'calls':>8} {'tottime':>10} {'tt/call':>10} {'cumtime':>10} {'ct/call':>10}")
                print(f"  {'-' * col_w} {'-' * 8} {'-' * 10} {'-' * 10} {'-' * 10} {'-' * 10}")
                for key in funcs:
                    filename, lineno, func_name = key
                    disp = f"{func_name} ({filename})" if filename != "<unknown>" else func_name
                    disp = disp[:col_w - 3] + "..." if len(disp) > col_w else disp
                    cc, nc, tt, ct, _ = stats.stats[key]
                    print(
                        f"  {disp:<{col_w}} {nc:>8}"
                        f" {format_time(tt):>10} {format_time(tt / nc if nc else 0):>10}"
                        f" {format_time(ct):>10} {format_time(ct / nc if nc else 0):>10}"
                    )

                if save_pstats:
                    prof_path = path.with_suffix(".prof")
                    stats.dump_stats(str(prof_path))
                    print(f"\n  Saved: {prof_path}")
                    print(f"  Run:   python -m pstats {prof_path}")


def print_profile_comparison(
    profiles: dict,
    top_n: int,
    filter_str: str = "",
    sort_key: str = "tottime",
    min_calls: int = 0,
    save_pstats: bool = False,
) -> None:
    """Compare top functions between baseline and candidate viztracer profiles.

    Loads ALL matching functions from both profiles before applying the top-N
    cutoff. Per-call comparison avoids skew from pyperf running different total
    iteration counts for faster vs slower builds.

    Uses pstats internally so B/call and C/call reflect exclusive time (tottime)
    rather than raw inclusive wall time.
    """
    # Map sort_key to pstats tuple index and label
    sort_col_map = {
        "tottime": (2, "tottime/call"),
        "time": (2, "tottime/call"),
        "percall": (2, "tottime/call"),
        "cumtime": (3, "cumtime/call"),
        "cumulative": (3, "cumtime/call"),
        "ncalls": (1, "calls"),
        "calls": (1, "calls"),
    }
    col_idx, col_label = sort_col_map.get(sort_key, (2, "tottime/call"))

    col_w = 80
    for scenario, configs in profiles.items():
        for config, versions in sorted(configs.items()):
            if "baseline" not in versions or "candidate" not in versions:
                missing = "candidate" if "baseline" in versions else "baseline"
                print(f"  Skipping {scenario}/{config}: {missing} profile not found", file=sys.stderr)
                continue

            notes = []
            if filter_str:
                notes.append(f"filter={filter_str!r}")
            if min_calls:
                notes.append(f"min_calls={min_calls}")
            notes_str = f" [{', '.join(notes)}]" if notes else ""
            print(f"\n{'=' * (col_w + 50)}")
            print(f"Profile comparison: {scenario}/{config}{notes_str} (sorted by {col_label} delta)")
            print(f"{'=' * (col_w + 50)}")

            print(f"  Loading baseline...", file=sys.stderr)
            b_stats = viztracer_to_pstats(
                versions["baseline"], filter_str=filter_str, strip_lineno=True, min_calls=min_calls
            )
            print(f"  Loading candidate...", file=sys.stderr)
            c_stats = viztracer_to_pstats(
                versions["candidate"], filter_str=filter_str, strip_lineno=True, min_calls=min_calls
            )

            b_dict = b_stats.stats  # {(filename, lineno, func_name): (cc, nc, tt, ct, {})}
            c_dict = c_stats.stats

            if save_pstats:
                for version, stats_obj, path in [("baseline", b_stats, versions["baseline"]), ("candidate", c_stats, versions["candidate"])]:
                    prof_path = path.with_suffix(".prof")
                    stats_obj.dump_stats(str(prof_path))
                    print(f"  Saved ({version}): {prof_path}")

            all_funcs = set(b_dict.keys()) | set(c_dict.keys())
            changes = []
            for func in all_funcs:
                b_cc, b_nc, b_tt, b_ct, _ = b_dict.get(func, (0, 0, 0.0, 0.0, {}))
                c_cc, c_nc, c_tt, c_ct, _ = c_dict.get(func, (0, 0, 0.0, 0.0, {}))

                if col_idx == 2:  # tottime
                    b_per = b_tt / b_nc if b_nc else 0.0
                    c_per = c_tt / c_nc if c_nc else 0.0
                elif col_idx == 3:  # cumtime
                    b_per = b_ct / b_nc if b_nc else 0.0
                    c_per = c_ct / c_nc if c_nc else 0.0
                else:  # ncalls
                    b_per = float(b_nc)
                    c_per = float(c_nc)

                delta = c_per - b_per
                pct = (delta / b_per * 100) if b_per else None
                changes.append((func, b_nc, c_nc, b_per, c_per, delta, pct))

            header = (
                f"  {'Function':<{col_w}} "
                f"{'B calls':>8} {'C calls':>8} "
                f"{'B ' + col_label:>14} {'C ' + col_label:>14} "
                f"{'Delta':>12} {'%':>7}"
            )
            divider = (
                f"  {'-' * col_w} {'-' * 8} {'-' * 8} {'-' * 14} {'-' * 14} {'-' * 12} {'-' * 7}"
            )

            regressions = sorted(
                [(f, b, c, bp, cp, dp, pct) for f, b, c, bp, cp, dp, pct in changes if dp > 0],
                key=lambda x: x[5],
                reverse=True,
            )
            improvements = sorted(
                [(f, b, c, bp, cp, dp, pct) for f, b, c, bp, cp, dp, pct in changes if dp < 0],
                key=lambda x: x[5],
            )

            def _row(func, b_nc, c_nc, b_per, c_per, delta, pct):
                filename, lineno, func_name = func
                disp = f"{func_name} ({filename})" if filename != "<unknown>" else func_name
                disp = disp[:col_w - 3] + "..." if len(disp) > col_w else disp
                pct_str = f"{pct:+.1f}%" if pct is not None else "new"
                print(
                    f"  {disp:<{col_w}} "
                    f"{int(b_nc):>8} {int(c_nc):>8} "
                    f"{format_time(b_per):>14} {format_time(c_per):>14} "
                    f"{('+' if delta >= 0 else '') + format_time(delta):>12} {pct_str:>7}"
                )

            print(f"\n  Top {top_n} regressions (by {col_label} delta):")
            print(header)
            print(divider)
            for row in regressions[:top_n]:
                _row(*row)

            print(f"\n  Top {top_n} improvements (by {col_label} delta):")
            print(header)
            print(divider)
            for row in improvements[:top_n]:
                _row(*row)


def main():
    parser = argparse.ArgumentParser(
        description="Analyze benchmark results from perf-run-scenario",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  # Summarize latest run
  scripts/perf-analyze artifacts/

  # JSON output for AI agents
  scripts/perf-analyze artifacts/ --json

  # Markdown table for PR comments
  scripts/perf-analyze artifacts/ --markdown

  # Show top 20 functions from viztracer profiling (ddtrace hot paths only)
  scripts/perf-analyze artifacts/ --profile-top 20 --filter ddtrace --min-calls 1000

  # Compare profiling data between baseline and candidate
  scripts/perf-analyze artifacts/ --profile-compare --filter ddtrace --min-calls 1000

  # Sort by cumtime instead of tottime
  scripts/perf-analyze artifacts/ --profile-compare --filter ddtrace --sort cumtime

  # Save pstats .prof files for interactive analysis
  scripts/perf-analyze artifacts/ --profile-compare --save-pstats
  python -m pstats artifacts/<run-id>/span/baseline/viztracer/start-finish.prof
        """,
    )

    parser.add_argument("artifacts_dir", help="Path to artifacts directory (or a specific run-id dir)")
    parser.add_argument("--json", action="store_true", help="Output JSON for AI agent consumption")
    parser.add_argument("--markdown", action="store_true", help="Output Markdown table for copy-paste into PR comments")
    parser.add_argument(
        "--profile-top",
        type=int,
        metavar="N",
        help="Show top N functions by duration from viztracer profiling",
    )
    parser.add_argument(
        "--profile-compare",
        action="store_true",
        help="Compare viztracer profiles between baseline and candidate",
    )
    parser.add_argument(
        "--filter",
        default="",
        metavar="PATTERN",
        help="Only include profiling functions whose name contains PATTERN (e.g. 'ddtrace')",
    )
    parser.add_argument(
        "--min-calls",
        type=int,
        default=0,
        metavar="N",
        help="Exclude functions called fewer than N times on both sides (filters startup/import noise)",
    )
    parser.add_argument(
        "--sort",
        default="tottime",
        metavar="KEY",
        help="Sort profiling results by: tottime (default), cumtime, ncalls, percall "
             "(tottime/ncalls). All standard pstats sort keys are also accepted.",
    )
    parser.add_argument(
        "--call-tree",
        metavar="FUNC",
        help="Show callers and callees for functions matching FUNC (substring match)",
    )
    parser.add_argument(
        "--save-pstats",
        action="store_true",
        help="Save .prof files next to each viztracer .json for use with python -m pstats",
    )

    args = parser.parse_args()

    artifacts_path = Path(args.artifacts_dir).resolve()
    if not artifacts_path.exists():
        print(f"Error: {artifacts_path} does not exist", file=sys.stderr)
        return 1

    run_dir = find_run_dir(artifacts_path)
    print(f"Run directory: {run_dir}", file=sys.stderr)

    results = discover_results(run_dir)
    if not results:
        print("No benchmark results found.", file=sys.stderr)
        return 1

    if args.json:
        output_json(results)
    elif args.markdown:
        output_markdown(results)
    else:
        print_summary(results)

    if args.profile_top or args.profile_compare or args.save_pstats or args.call_tree:
        profiles = discover_viztracer_files(run_dir)
        if not profiles:
            print("\nNo viztracer profiling data found.", file=sys.stderr)
            print("Run benchmarks with --profile to collect profiling data.", file=sys.stderr)
            return 1

        if args.call_tree:
            print_call_tree(
                profiles,
                func_pattern=args.call_tree,
                filter_str=args.filter,
                min_calls=args.min_calls,
            )

        top_n = args.profile_top or 10
        if args.profile_compare:
            print_profile_comparison(
                profiles,
                top_n=top_n,
                filter_str=args.filter,
                sort_key=args.sort,
                min_calls=args.min_calls,
                save_pstats=args.save_pstats,
            )
        elif args.profile_top:
            print_profile_top(
                profiles,
                top_n=top_n,
                filter_str=args.filter,
                sort_key=args.sort,
                min_calls=args.min_calls,
                save_pstats=args.save_pstats,
            )
        elif args.save_pstats:
            # --save-pstats without --profile-top/compare: just export all profiles
            print_profile_top(
                profiles,
                top_n=0,
                filter_str=args.filter,
                min_calls=args.min_calls,
                save_pstats=True,
            )

    return 0


if __name__ == "__main__":
    sys.exit(main())
