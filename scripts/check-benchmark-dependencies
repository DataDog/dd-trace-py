#!/usr/bin/env scripts/uv-run-script
# -*- mode: python -*-
# /// script
# dependencies = []
# ///
"""
Check that benchmark dependency lock files are not stale.

This script does NOT re-compile requirements — re-running the generator
legitimately picks up newer transitive versions, which is the intended
behaviour of lock-file refreshes.

Instead it enforces a simpler invariant: if a `.in` source file was edited
in this branch, the corresponding `.txt` lock file must also have been
updated (i.e. the developer ran scripts/update-benchmark-dependencies and
committed the result).

Checked files:
  benchmarks/base/requirements.in          → benchmarks/base/requirements.txt
  benchmarks/<scenario>/requirements_scenario.in
      → benchmarks/<scenario>/requirements_scenario.txt

If a .in changed but the .txt did not, the script fails and prints
instructions to regenerate.

Usage:
    scripts/check-benchmark-dependencies
"""

import subprocess
import sys
from pathlib import Path


BASE_IN = Path("benchmarks/base/requirements.in")
BASE_TXT = Path("benchmarks/base/requirements.txt")
# When base changes, ALL scenario locks must also be regenerated (they embed base deps)
SCENARIO_GLOB = "benchmarks/*/requirements_scenario.in"


def get_changed_files() -> set[str]:
    """
    Return the set of files changed relative to the merge base with origin/main.

    Falls back to comparing HEAD with origin/main directly if merge-base
    resolution fails (e.g. shallow clone without fetch depth).
    """
    try:
        result = subprocess.run(
            ["git", "diff", "--name-only", "origin/main...HEAD"],
            capture_output=True,
            text=True,
            check=True,
        )
        return set(result.stdout.strip().splitlines())
    except subprocess.CalledProcessError:
        pass

    # Fallback: diff staged + unstaged changes on top of origin/main
    try:
        result = subprocess.run(
            ["git", "diff", "--name-only", "origin/main"],
            capture_output=True,
            text=True,
            check=True,
        )
        return set(result.stdout.strip().splitlines())
    except subprocess.CalledProcessError as e:
        print(f"Warning: could not determine changed files: {e}", file=sys.stderr)
        return set()


def find_scenario_dirs() -> list[Path]:
    """Return sorted list of scenario directories with a requirements_scenario.in."""
    benchmarks_dir = Path("benchmarks")
    return sorted(
        p.parent
        for p in benchmarks_dir.glob("*/requirements_scenario.in")
        if p.parent.name not in ("base", "bm")
    )


def main() -> int:
    """Main entry point."""
    changed = get_changed_files()
    if not changed:
        print("No changed files detected (or git comparison unavailable) — skipping check")
        return 0

    violations: list[str] = []

    # Check base requirements.in → requirements.txt (and implicitly all scenario locks,
    # since scenario locks embed base deps — a base change should prompt full refresh)
    if str(BASE_IN) in changed and str(BASE_TXT) not in changed:
        violations.append(
            f"  {BASE_IN} was modified but {BASE_TXT} was not updated.\n"
            f"  Run scripts/update-benchmark-dependencies to regenerate ALL lock files."
        )

    # Check each scenario's requirements_scenario.in → requirements_scenario.txt
    for scenario_dir in find_scenario_dirs():
        scenario_in = scenario_dir / "requirements_scenario.in"
        scenario_txt = scenario_dir / "requirements_scenario.txt"

        if str(scenario_in) in changed and str(scenario_txt) not in changed:
            violations.append(
                f"  {scenario_in} was modified but {scenario_txt} was not updated.\n"
                f"  Run scripts/update-benchmark-dependencies to regenerate the lock file."
            )

    if violations:
        print("❌ Benchmark dependency lock files are stale:\n")
        for v in violations:
            print(v)
        print()
        print("=" * 72)
        print("How to fix:")
        print("  scripts/update-benchmark-dependencies")
        print("  git add benchmarks/")
        print("  git commit -m 'chore(benchmarks): refresh dependency lock files'")
        print("=" * 72)
        return 1

    print("✅ Benchmark dependency lock files are up to date")
    return 0


if __name__ == "__main__":
    sys.exit(main())
