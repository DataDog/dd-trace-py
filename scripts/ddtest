#!/usr/bin/env bash

set -e

CMD=$*

if [ -z "$CMD" ]
then
    CMD=bash
fi

BUILD_FLAG=""
if [ "${1:-}" = "--build" ]; then
    BUILD_FLAG="--build"
    shift
fi
# Ensure cache directories exist and are writable by the current user
# These are mounted into the Docker container at /home/bits/.cache
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
CACHE_DIR="$PROJECT_ROOT/.cache"

# Create cache directories if they don't exist
mkdir -p "$CACHE_DIR/pip" "$CACHE_DIR/cython" "$CACHE_DIR/sccache" 2>/dev/null || true

# Fix permissions if the cache directory is owned by root
if [ -d "$CACHE_DIR" ] && [ "$(stat -c '%U' "$CACHE_DIR" 2>/dev/null || stat -f '%Su' "$CACHE_DIR" 2>/dev/null)" = "root" ]; then
    echo "Warning: $CACHE_DIR is owned by root. Attempting to fix permissions..."
    echo "You may be prompted for your sudo password."
    sudo chown -R "$USER:$(id -gn)" "$CACHE_DIR" 2>/dev/null || {
        echo "Error: Failed to fix cache directory permissions."
        echo "Please run: sudo chown -R \$USER:\$(id -gn) $CACHE_DIR"
        exit 1
    }
fi

# Ensure the directories are writable
chmod -R u+w "$CACHE_DIR" 2>/dev/null || true

# Generate a per-run compose project name from the project root path so that
# concurrent runs in different worktrees get isolated compose projects.
if [ -z "${COMPOSE_PROJECT_NAME:-}" ]; then
    PATH_HASH=$(echo -n "$PROJECT_ROOT" | shasum | head -c 8)
    export COMPOSE_PROJECT_NAME="ddtracepy-${PATH_HASH}"
fi

# Handle git worktree: mount the common git directory so that git works inside
# the container even when .git is a file pointing outside the mount.
EXTRA_VOLUMES=()
GIT_DIR_FILE="$PROJECT_ROOT/.git"
if [ -f "$GIT_DIR_FILE" ]; then
    GIT_COMMON_DIR=$(cd "$PROJECT_ROOT" && git rev-parse --git-common-dir)
    # Resolve to absolute path
    GIT_COMMON_DIR=$(cd "$PROJECT_ROOT" && cd "$GIT_COMMON_DIR" && pwd)
    EXTRA_VOLUMES+=("-v" "${GIT_COMMON_DIR}:${GIT_COMMON_DIR}:ro")
fi

COMPOSE_FILES=("-f" "$PROJECT_ROOT/docker-compose.yml")
if command -v nvidia-smi >/dev/null 2>&1; then
    COMPOSE_FILES+=("-f" "$PROJECT_ROOT/docker-compose.gpu.yml")
fi

docker compose ${COMPOSE_FILES[@]} run $BUILD_FLAG \
       -e DD_TRACE_AGENT_URL \
       ${EXTRA_VOLUMES[@]+"${EXTRA_VOLUMES[@]}"} \
       --rm \
       -i \
       testrunner \
       bash -c "(git config --global --add safe.directory /home/bits/project || true) && (git config --global --add safe.directory ${GIT_COMMON_DIR:-/home/bits/project} || true) && $CMD"
