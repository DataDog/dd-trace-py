{
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(python:*)",
      "Bash(./scripts/events/generate_stub.py:*)",
      "Bash(./scripts/ddtest:*)",
      "Bash(scripts/ddtest:*)",
      "Bash(scripts/run-tests:*)",
      "Bash(gh pr list:*)",
      "Bash(git remote:*)",
      "Bash(pyenv versions:*)",
      "Bash(pyenv virtualenv:*)",
      "Bash(mkdir:*)",
      "Bash(docker compose build:*)",
      "Bash(riot list:*)",
      "Bash(riot -v run:*)",
      "Bash(scripts/lint:*)",
      "Bash(cargo:*)",
      "Bash(source:*)",
      "Bash(pip install:*)",
      "Bash(git grep:*)",
      "Bash(ast-grep scan:*)",
      "Bash(awk:*)",
      "Bash(jj:*)",
      "WebFetch(domain:ast-grep.github.io)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "mcp__atlassian__getJiraIssue",
      "mcp__github__search_pull_requests",
      "mcp__github__get_pull_request",
      "mcp__github__get_pull_request_review_comments",
      "mcp__github__pull_request_read",
      "Skill(run-tests)",
      "Skill(lint)",
      "Skill(find-cpython-usage)",
      "Skill(compare-cpython-versions)",
      "Skill(releasenote)",
      "Skill(review-ci)"
    ],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_SETTINGS_DIR}/hooks/detect-native-build-error.py"
          }
        ]
      }
    ]
  }
}
